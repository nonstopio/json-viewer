{
  "name": "json-viewer-analytics",
  "private": true,
  "version": "1.4.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint --ext .js,.ts,.tsx .",
    "lint:fix": "eslint --ext .js,.ts,.tsx . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\" \".eslintrc.cjs\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json}\" \".eslintrc.cjs\"",
    "code-quality": "npm run format && npm run lint:fix && npm run build",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@uiw/react-codemirror": "^4.25.11",
    "@xyflow/react": "^12.11.2",
    "dagre": "^0.8.5",
    "html-to-image": "^1.11.13",
    "json-parse-even-better-errors": "^4.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-virtuoso": "^4.18.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.61.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/dagre": "^0.7.54",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "husky": "^9.1.7",
    "postcss": "^8.4.27",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.8",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  }
}
